{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "none",
  "imports": {
    "@actions/core": "npm:@actions/core@^3.0.0",
    "@alicloud/cdn20180510": "npm:@alicloud/cdn20180510@8.0.0",
    "@alicloud/credentials": "npm:@alicloud/credentials@^2.4.4",
    "ali-oss": "npm:ali-oss@^6.23.0",
    "lefthook": "npm:lefthook@^2.1.3",
    "mime-types": "npm:mime-types@^3.0.2"
  },
  "permissions": {
    "lume": {
      "read": true,
      "write": ["./"],
      "import": [
        "cdn.jsdelivr.net:443",
        "cdn.sheetjs.com:443",
        "jsr.io:443",
        "deno.land:443"
      ],
      "net": [
        "0.0.0.0",
        "jsr.io:443",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "fonts.googleapis.com:443",
        "fonts.gstatic.com:443",
        "registry.npmjs.org:443",
        "contrib.rocks:443",
        "localhost:4318",
        "127.0.0.1:4318"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "lint": {
    "exclude": ["dist"]
  },
  "fmt": {
    "exclude": ["CHANGELOG.md"]
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true
  },
  "unstable": ["temporal", "fmt-component"],
  "tasks": {
    "lint": {
      "description": "Run Deno lint checks",
      "command": "deno lint"
    },
    "check": {
      "description": "Run Deno type checks on source files",
      "command": "deno check src/pre.ts src/main.ts src/post.ts src/lint-commit.ts"
    },
    "lint-commit": {
      "description": "Validate a commit message against Conventional Commits rules",
      "command": "deno run --allow-read --allow-env --allow-sys src/lint-commit.ts"
    },
    "hooks:install": {
      "description": "Install Git hooks via Lefthook",
      "command": "deno run --no-lock -A npm:lefthook install"
    },
    "bundle:pre": {
      "description": "Bundle the pre action entrypoint",
      "command": "deno bundle --format=esm --platform=deno --sourcemap=linked --output dist/pre/index.js src/pre.ts"
    },
    "bundle:main": {
      "description": "Bundle the main action entrypoint",
      "command": "deno bundle --format=esm --platform=deno --external=proxy-agent --sourcemap=linked --output dist/main/index.js src/main.ts"
    },
    "bundle:post": {
      "description": "Bundle the post action entrypoint",
      "command": "deno bundle --format=esm --platform=deno --external=proxy-agent --sourcemap=linked --output dist/post/index.js src/post.ts"
    },
    "package": {
      "description": "Bundle all action entrypoints",
      "command": "deno task bundle:pre && deno task bundle:main && deno task bundle:post"
    },
    "build": {
      "description": "Run lint, check, package, and format tasks",
      "command": "deno task lint && deno task check && deno task package && deno fmt"
    },
    "check-dist": {
      "description": "Rebuild dist and fail if artifacts changed",
      "command": "deno task package && git diff --ignore-space-at-eol --exit-code -- dist"
    },
    "update-deps": {
      "description": "Update dependencies and regenerate lock file",
      "command": "deno outdated --update --latest"
    }
  }
}
